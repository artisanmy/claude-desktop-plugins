{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Plugin Registry",
  "type": "object",
  "required": ["version", "plugins"],
  "properties": {
    "version": { "type": "string" },
    "updated": { "type": "string", "format": "date" },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/definitions/plugin" }
    }
  },
  "definitions": {
    "plugin": {
      "type": "object",
      "required": ["id", "name", "description", "version", "author", "path"],
      "properties": {
        "id":               { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name":             { "type": "string" },
        "description":      { "type": "string" },
        "version":          { "type": "string" },
        "author":           { "type": "string" },
        "category":         { "type": "string", "enum": ["productivity", "utilities", "developer", "data", "communication", "other"] },
        "tags":             { "type": "array", "items": { "type": "string" } },
        "minClaudeVersion": { "type": "string" },
        "path":             { "type": "string" },
        "releaseUrl":       { "type": "string", "format": "uri" },
        "changelog":        { "type": "string" }
      }
    }
  }
}
