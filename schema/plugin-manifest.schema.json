{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Plugin Manifest",
  "description": "Schema for a plugin's plugin.json manifest file",
  "type": "object",
  "required": ["id", "name", "version", "description", "author"],
  "properties": {
    "id":          { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name":        { "type": "string" },
    "version":     { "type": "string" },
    "description": { "type": "string" },
    "author":      { "type": "string" },
    "category":    { "type": "string" },
    "tags":        { "type": "array", "items": { "type": "string" } },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "path":        { "type": "string" }
        }
      }
    },
    "mcpServers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "command": { "type": "string" },
          "args":    { "type": "array", "items": { "type": "string" } },
          "env":     { "type": "object" }
        }
      }
    }
  }
}
